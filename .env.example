# ─────────────────────────────────────────────────────────────────────────────
# Root .env — values here are substituted into docker-compose.yml at build time.
# Copy to .env and fill in your values before running `docker compose up`.
#
# NOTE: Each service also reads its own backend/<service>/.env.local at runtime.
# Override DB_HOST / DB_PORT there is NOT needed — docker-compose.yml sets them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASS=0023

# ── Frontend build-time (NEXT_PUBLIC_) vars ───────────────────────────────────
# These are baked into the client JS bundle at `docker compose build` time.
# If you change them you must rebuild the frontend image.

NEXT_PUBLIC_COGNITO_REGION=ap-south-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=
NEXT_PUBLIC_AUTH_REDIRECT_SIGNIN=http://localhost:3000
NEXT_PUBLIC_AUTH_REDIRECT_SIGNOUT=http://localhost:3000

# Point these at the docker-compose service ports on your Docker host
NEXT_PUBLIC_ADMIN_API_BASE_URL=http://localhost:4001
NEXT_PUBLIC_AUTH_API_BASE_URL=http://localhost:4002
NEXT_PUBLIC_CORPORATE_API_BASE_URL=http://localhost:4003
NEXT_PUBLIC_CORPORATE_API_URL=http://localhost:4003
NEXT_PUBLIC_STUDENT_API_URL=http://localhost:4004
NEXT_PUBLIC_EXAM_ENGINE_API_URL=http://localhost:4005
NEXT_PUBLIC_REPORT_API_BASE_URL=http://localhost:4004
